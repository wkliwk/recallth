# Copy this file to .env.local and fill in your values
# Never commit .env.local to git

# Backend API URL
# Get this from: Railway dashboard → your recallth-backend service → Settings → Public URL
VITE_API_URL=https://recallth-backend.up.railway.app

# Google OAuth Client ID (for Google SSO)
# Get this from: Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client IDs
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
